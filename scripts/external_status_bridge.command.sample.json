{
  "source": {
    "type": "command",
    "command": "bb status {crew}",
    "cwd": "~/your-runtime-dir",
    "timeoutSec": 12,
    "lineFilter": "{agent} "
  },
  "stateMap": {
    "busy": "writing",
    "thinking": "researching",
    "dead": "error",
    "sync": "syncing"
  },
  "defaultState": "idle",
  "agents": [
    {
      "agentId": "agent_xxx",
      "name": "CrewA co",
      "crew": "crew-a",
      "agent": "co",
      "sourceKey": "crew-a.co",
      "detailTemplate": "{name} | state={state} | {raw}"
    }
  ]
}
